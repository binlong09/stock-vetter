# Required
ANTHROPIC_API_KEY=

# Optional: User-Agent for SEC EDGAR (SEC requires identification on requests).
# Format: "Your Name your@email.com"
SEC_USER_AGENT=

# Required for the Signal Tracker (packages/signals): Financial Modeling Prep
# API key. Powers earnings-call transcripts, consensus estimates, and
# estimate-revision history. Get a key at
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# Turso (libSQL) database. Used by the read-only web viewer AND as the
# AUTHORITATIVE state store for the Signal Tracker (per-thesis cursors +
# tripwire status — see packages/signals). When set, `analyze-ticker` pushes
# decision cards and `track` persists/reads cursors here. When unset, the
# tracker falls back to the local .cache/signals/ cursor store (no status
# persistence) and the analyze CLI is fixtures-only.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Signal Tracker scheduled cron (.github/workflows/signal-tracker.yml)
# ---------------------------------------------------------------------------
# The daily GitHub Actions run needs these as repository/organization SECRETS
# (Settings → Secrets and variables → Actions), NOT in this file:
#   ANTHROPIC_API_KEY    — LLM evaluation
#   FMP_API_KEY          — consensus estimates + ratings revisions
#   TURSO_DATABASE_URL   — authoritative cursor/status store
#   TURSO_AUTH_TOKEN
#   SEC_USER_AGENT       — "Your Name your@email.com"
# Steady-state runs are cents (cursor-gated). Only a cold start (new thesis or
# ticker) is expensive, and the cold-start guard in track.ts makes that an
# explicit opt-in (--allow-backlog) rather than an accident.
