# Required
ANTHROPIC_API_KEY=

# Optional: User-Agent for SEC EDGAR (SEC requires identification on requests).
# Format: "Your Name your@email.com"
SEC_USER_AGENT=

# Required for the Signal Tracker (packages/signals): Financial Modeling Prep
# API key. Powers earnings-call transcripts, consensus estimates, and
# estimate-revision history. Get a key at
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# Optional: Turso (libSQL) database for the read-only web viewer. When both are
# set, `analyze-ticker` pushes each successful run into Turso after writing the
# local fixtures (a push failure logs a warning but never fails the run). When
# unset, the CLI works exactly as before — fixtures only, no remote push.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
