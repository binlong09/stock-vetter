# Turso (libSQL) — the same database the CLI pushes to. Read-only from the web app.
TURSO_DATABASE_URL=libsql://stock-vetter-<you>.turso.io
TURSO_AUTH_TOKEN=

# Auth.js (NextAuth v5). Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=

# Resend magic-link email. Create a key at https://resend.com/api-keys
AUTH_RESEND_KEY=
# From-address for magic-link emails. For testing you can use Resend's sandbox
# sender; for production use a verified domain.
EMAIL_FROM="Stock Vetter <onboarding@resend.dev>"

# Sign-in allowlist: NOT an env var. It lives in the `allowed_emails` Turso
# table (migration 0004) so a reader can be added with `pnpm allow-email <addr>`
# — no env change, no Vercel redeploy. Fails closed if the table is empty.
# Seed it once with: pnpm allow-email you@example.com

# Production only (set in Vercel, not locally): the deployed origin, so magic-link
# callback URLs in emails point at production instead of localhost.
# AUTH_URL=https://your-app.vercel.app

# Bearer token Vercel cron uses to call /api/cron/eod-prices. Generate with
# `openssl rand -hex 32` and set both here (so manual curl tests work) and in
# the Vercel project's environment variables. Fails closed if unset.
CRON_SECRET=

# GitHub fine-grained PAT for the "Run analysis now" button (/api/trigger-run).
# Needs only Actions: write on binlong09/stock-vetter so the route can fire the
# signal-tracker workflow via workflow_dispatch. SERVER-ONLY — set it in Vercel,
# never expose to the client. If unset, the trigger route returns 503 and the
# button is inert (the cron still runs on schedule).
GH_DISPATCH_TOKEN=
